# ─── Vite frontend (prefix with VITE_ to expose to browser) ─────────────────
VITE_API_URL=https://game.rrdream.in
VITE_API_BASE_URL=https://game.rrdream.in/api/

# ─── Express backend ─────────────────────────────────────────────────────────
SERVER_PORT=3004

# Firebase service account JSON filename (place file in the project root)
FIREBASE_SERVICE_ACCOUNT_FILENAME=rrdream-4d72e-firebase-adminsdk-fbsvc-879335a36d.json
# Optional: absolute path override for the service account file
FIREBASE_SERVICE_ACCOUNT_PATH=

# FCM broadcast topic sent to all users
FCM_BROADCAST_TOPIC=all-users
# Android package name for click_action routing
FCM_ANDROID_PACKAGE_NAME=com.rr.dream

# Bearer token that protects the /api/notifications/close-reminders cron endpoint
FCM_REMINDER_CRON_SECRET=
# Bearer token used when calling the external game API to fetch closing times
FCM_REMINDER_API_BEARER_TOKEN=

# How many minutes before game close time to send the reminder
FCM_REMINDER_MINUTES=5
# Sliding window (seconds) to avoid duplicate reminders for the same game
FCM_REMINDER_WINDOW_SECONDS=75
# UTC offset in minutes for the game server timezone (330 = IST, UTC+5:30)
FCM_REMINDER_TIMEZONE_OFFSET_MINUTES=330
